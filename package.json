{
  "name": "timeslice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "TimeSlice — a personal time-tracking PWA. Log time in 15-minute increments across editable 3-level categories, with weekly views and reporting.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
